---
import { stats } from '@/data/portfolio';
---

<section id="about" class="py-28">
  <div class="container">
    <div class="mb-14">
      <span class="reveal-up block text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-4">
        About
      </span>
      <h2 class="reveal-up delay-1 text-[clamp(1.8rem,4vw,2.5rem)] font-bold tracking-[-0.025em] leading-tight">
        A bit about me
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-20 items-start">
      <!-- Text -->
      <div class="space-y-5">
        <p class="reveal-left text-[0.95rem] text-muted-foreground leading-[1.85]">
          I'm a developer who genuinely cares about how things look and feel. Not just the code — the whole experience. From how a button responds to a click, to the spacing between elements, to whether the page loads half a second faster.
        </p>
        <p class="reveal-left delay-1 text-[0.95rem] text-muted-foreground leading-[1.85]">
          My path started with curiosity — taking apart websites to understand how they worked. That curiosity became a craft. I believe in writing code that's as clean as the design it produces.
        </p>
        <p class="reveal-left delay-2 text-[0.95rem] text-muted-foreground leading-[1.85]">
          When I'm not building things, you'll find me exploring design systems, reading about typography, or trying to brew coffee that doesn't taste burned. Always looking for the next interesting problem to solve.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-3">
        {stats.map((stat, i) => (
          <div class={`reveal-scale delay-${Math.min(i + 1, 4)} group p-5 rounded-xl border border-border bg-card transition-all duration-500 ease-out hover:border-accent/30 relative overflow-hidden`}>
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[hsl(var(--clr-accent)/0.4)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            <div class="stat-value text-2xl font-extrabold tracking-[-0.03em] mb-0.5 text-foreground" data-value={stat.value}>
              {stat.value}
            </div>
            <div class="text-[0.72rem] text-muted-foreground font-medium">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Animate stat counters when visible
  const statCards = document.querySelectorAll('.stat-value');
  const counter = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const raw = el.dataset.value || '';
        const num = parseInt(raw);

        if (!isNaN(num)) {
          const suffix = raw.replace(String(num), '');
          let current = 0;
          const step = Math.ceil(num / 30);
          const interval = setInterval(() => {
            current = Math.min(current + step, num);
            el.textContent = current + suffix;
            if (current >= num) clearInterval(interval);
          }, 40);
        }

        counter.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  statCards.forEach((el) => counter.observe(el));
</script>
