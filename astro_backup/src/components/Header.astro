---
import ThemeToggle from '@/components/ThemeToggle';
import MobileMenu from '@/components/MobileMenu';

const navItems = [
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Stack' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-500">
  <div class="absolute inset-0 bg-background/70 backdrop-blur-xl saturate-[180%] -z-10"></div>
  <div class="container flex items-center justify-between h-16">
    <a href="#hero" class="flex items-center gap-2 font-bold text-foreground transition-transform duration-200 hover:scale-[1.02]">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 text-xs font-extrabold text-white">F</span>
      <span class="tracking-tight text-sm">fauzan.</span>
    </a>

    <nav class="hidden md:block">
      <ul class="flex items-center gap-0.5" id="navLinks">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link relative flex items-center px-3 py-1.5 rounded-md text-[0.82rem] font-medium text-muted-foreground transition-all duration-200 hover:text-foreground">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-2.5">
      <ThemeToggle client:load />
      <MobileMenu client:load />
    </div>
  </div>
</header>

<style>
  #header.scrolled {
    border-color: hsl(var(--border));
  }
  .nav-link.active {
    color: hsl(var(--foreground));
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 2px;
    background: hsl(165, 60%, 40%);
    border-radius: 1px;
    animation: dot-in 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes dot-in {
    from { width: 0; opacity: 0; }
    to { width: 12px; opacity: 1; }
  }
</style>

<script>
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');
  const header = document.getElementById('header');

  function update() {
    const scrollY = window.scrollY;
    let currentId = '';
    sections.forEach((s) => {
      const el = s as HTMLElement;
      if (scrollY >= el.offsetTop - 120 && scrollY < el.offsetTop + el.offsetHeight - 120) {
        currentId = el.id;
      }
    });
    navLinks.forEach((l) => {
      l.classList.toggle('active', l.getAttribute('href') === '#' + currentId);
    });
    header?.classList.toggle('scrolled', scrollY > 40);
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
