---
import ProjectSlider from "@/components/ProjectSlider";
import { projects } from "@/data/portfolio";
---

<section id="projects" class="py-28 relative">
    <div class="container">
        <!-- Header -->
        <div class="mb-20">
            <span
                class="reveal-up block text-xs font-semibold uppercase tracking-[0.12em] text-accent mb-4"
            >
                Selected Work
            </span>
            <h2
                class="reveal-up delay-1 text-[clamp(2rem,5vw,3rem)] font-bold tracking-[-0.025em] leading-tight mb-4"
            >
                Featured Projects
            </h2>
            <p
                class="reveal-up delay-2 text-muted-foreground max-w-[540px] leading-relaxed text-lg"
            >
                A curated selection of my most impactful work, showcasing
                problem-solving and technical craftsmanship.
            </p>
        </div>

        <!-- Slider -->
        <div class="reveal-up delay-3">
            <ProjectSlider projects={projects} client:visible />
        </div>
    </div>
</section>
