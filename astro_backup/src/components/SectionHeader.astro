---
interface Props {
  label: string;
  title: string;
  description?: string;
  icon?: 'folder' | 'code' | 'user' | 'mail';
}

const { label, title, description, icon } = Astro.props;

const iconPaths: Record<string, string> = {
  folder: '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  user: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
};
---

<div class="mb-12 reveal">
  <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.08em] text-blue-500 mb-4">
    {icon && (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[icon]} />
    )}
    {label}
  </span>
  <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] font-bold tracking-[-0.025em] leading-tight mb-4">
    {title}
  </h2>
  {description && (
    <p class="text-base text-muted-foreground max-w-[540px] leading-relaxed">
      {description}
    </p>
  )}
</div>
